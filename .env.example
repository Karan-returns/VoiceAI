# LiveKit (WebRTC transport + Inference LLM — no OpenAI key needed)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (STT Nova-2 + TTS Aura)
DEEPGRAM_API_KEY=

# STT — Deepgram Nova-2 (assignment requirement)
STT_PROVIDER=deepgram
STT_MODEL=nova-2-general
STT_LANGUAGE=en

# LLM — LiveKit Inference routes to GPT-4o (uses LiveKit keys, not your OpenAI key)
LLM_PROVIDER=livekit
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.7

# TTS — Deepgram Aura (swap to livekit + elevenlabs/* when you have Inference TTS)
TTS_PROVIDER=deepgram
TTS_MODEL=aura-asteria-en
TTS_VOICE=aura-asteria-en

# Logging
LOG_LEVEL=info

# MongoDB (Compass: connect with same URI, database = novatel, collection = conversations)
MONGODB_URI=mongodb://127.0.0.1:27017/novatel
