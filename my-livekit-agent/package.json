{
  "name": "my-livekit-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/tests/promptEvolutionFailureExtraction.run.ts",
    "test:llmNode": "tsx src/tests/llmNode.run.ts",
    "test:pipelineLatency": "tsx src/tests/pipelineLatency.run.ts",
    "test:promptEvolution": "tsx src/tests/promptEvolutionFailureExtraction.run.ts",
    "seed:billing": "tsx src/scripts/seedBilling.ts",
    "analyze:call": "tsx src/scripts/analyzeCall.ts",
    "evolve:prompt": "tsx src/scripts/evolvePrompt.ts",
    "export:recording": "tsx src/scripts/exportRecording.ts",
    "purge:recordings": "tsx src/scripts/purgeOrphanedRecordings.ts",
    "atlas:verify": "tsx src/scripts/verifyAtlas.ts",
    "dev": "tsx src/agent.ts dev",
    "start": "node dist/agent.js start",
    "download-files": "npx livekit-agents download-files"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@livekit/agents": "^1.4.4",
    "@livekit/agents-plugin-assemblyai": "^1.4.4",
    "@livekit/agents-plugin-cartesia": "^1.4.4",
    "@livekit/agents-plugin-deepgram": "^1.4.4",
    "@livekit/agents-plugin-elevenlabs": "^1.4.4",
    "@livekit/agents-plugin-livekit": "^1.4.4",
    "@livekit/agents-plugin-openai": "^1.4.4",
    "@livekit/agents-plugin-silero": "^1.4.4",
    "@livekit/noise-cancellation-node": "^0.1.0",
    "dotenv": "^17.4.1",
    "fluent-ffmpeg": "^2.1.3",
    "mongodb": "^6.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
