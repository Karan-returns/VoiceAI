# LiveKit (WebRTC transport + Inference LLM — no OpenAI key needed)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional — only needed when STT/TTS_PROVIDER=deepgram (not required for LiveKit Inference)
DEEPGRAM_API_KEY=

# STT — LiveKit Inference (fastest: Cartesia Ink Whisper ~80ms)
STT_PROVIDER=livekit
STT_MODEL=cartesia/ink-whisper
STT_LANGUAGE=en

# LLM — LiveKit Inference (fastest: GPT-4.1 nano ~200ms; uses LiveKit keys only)
LLM_PROVIDER=livekit
LLM_MODEL=openai/gpt-4.1-nano
LLM_TEMPERATURE=0.55

# TTS — LiveKit Inference (fastest: Cartesia Sonic Turbo ~90ms)
TTS_PROVIDER=livekit
TTS_MODEL=cartesia/sonic-turbo
TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02

# Logging
LOG_LEVEL=info

# MongoDB (Compass: connect with same URI, database = novatel)
# Collections: conversations, billing_accounts, agent_prompts
MONGODB_URI=mongodb://127.0.0.1:27017/novatel

# Post-call analysis (Loop 2 prerequisite — runs after each completed call)
CALL_ANALYSIS_ENABLED=true

# Post-call prompt evolution (Loop 2 — auto-patches base prompt from recurring failures)
PROMPT_EVOLUTION_ENABLED=true
MIN_CORRECTION_REPEAT_COUNT=2

# Call recording — full mixed MP3 (customer + agent) stored in MongoDB GridFS by callId.
# Uses the built-in in-process recorder, transcoded to MP3 via ffmpeg. Requires MONGODB_URI.
RECORDING_ENABLED=true
